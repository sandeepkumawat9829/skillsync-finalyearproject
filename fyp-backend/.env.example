# FYP Management System - Environment Variables Template
# Copy this file to `.env` or set these variables in your deployment environment

# Server
PORT=8080

# Database Configuration (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/fypdb
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT Authentication
# Must be at least 256 bits (32 characters)
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production
JWT_EXPIRATION=86400000

# Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (SMTP)
EMAIL_USERNAME=your_gmail_address@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# CORS Settings (Allowed Origins)
# For local dev: http://localhost:4200
# For prod: https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:4200
